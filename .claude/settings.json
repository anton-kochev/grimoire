{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/router.ts\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/router.ts\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "grimoire.csharp-coder|grimoire.typescript-coder|grimoire.vue3-coder|grimoire.dotnet-unit-test-writer",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/router.ts\" --subagent-start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "grimoire.csharp-coder|grimoire.typescript-coder|grimoire.vue3-coder|grimoire.dotnet-unit-test-writer",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/router.ts\" --subagent-stop"
          }
        ]
      }
    ]
  }
}
